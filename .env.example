# Incident Captain local environment template
# Copy to `.env` only for local use. Do not commit real secrets.

# GitHub
GITHUB_TOKEN=ghp_your_token_here

# PagerDuty
PAGERDUTY_API_TOKEN=your_pagerduty_token_here

# Slack
SLACK_TOKEN=xoxb-your-slack-token-here

# Datadog
DD_API_KEY=your_datadog_api_key_here
DD_APPLICATION_KEY=your_datadog_application_key_here

# Optional: OpenObserve (if using instead of Datadog)
# OPENOBSERVE_URL=https://api.openobserve.ai
# OPENOBSERVE_ORG=default
# OPENOBSERVE_USERNAME=your_username
# OPENOBSERVE_PASSWORD=your_password

